    <packaging>pom</packaging>
    <modules>
        <module>family-core</module>
        <module>family-framework</module>
        <module>openapi-debug-console-spring-boot-starter</module>
        <module>family-ai</module>
        <module>family-uaa</module>
        <module>family-gateway</module>
        <module>family-cache-spring-boot-starter</module>
        <module>pg-ddd-codegen</module>
    </modules>
    <groupId>top.egon</groupId>
    <artifactId>family-ai-butler-backend</artifactId>
    <version>0.0.1-SNAPSHOT</version>
    <name>FamilyAiButler</name>
    <description>FamilyAiButler</description>
    <url>https://github.com/AllenDEricDAlexander/FamilyAiButler</url>
    <licenses>
        <license>
            <name>MIT License</name>
            <url>https://opensource.org/licenses/MIT</url>
            <distribution>repo</distribution>
        </license>
    </licenses>
    <developers>
        <developer>
            <name>egon</name>
            <email>mqa010225@gmail.com</email>
            <organization>FamilyAiButler</organization>
            <organizationUrl>https://github.com/AllenDEricDAlexander</organizationUrl>
        </developer>
    </developers>
    <scm>
        <connection>scm:git:https://github.com/AllenDEricDAlexander/FamilyAiButler</connection>
        <developerConnection>scm:git:https://github.com/AllenDEricDAlexander/FamilyAiButler</developerConnection>
        <tag>FamilyAiButler</tag>
        <url>https://github.com/AllenDEricDAlexander/FamilyAiButler</url>
    </scm>
    <properties>
        <java.version>21</java.version>
        <maven.compiler.source>${java.version}</maven.compiler.source>
        <maven.compiler.target>${java.version}</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <spring-cloud.version>2025.0.2</spring-cloud.version>
        <spring-ai.version>1.1.6</spring-ai.version>
        <spring-ai-alibaba.version>1.1.2.3</spring-ai-alibaba.version>
        <spring-cloud-alibaba.version>2025.0.0.0</spring-cloud-alibaba.version>
        <dubbo.version>3.3.4</dubbo.version>
        <grpc.version>1.69.0</grpc.version>
        <mybatis-plus.version>3.5.12</mybatis-plus.version>
        <postgresql.version>42.7.7</postgresql.version>
        <zxcvbn.version>1.9.0</zxcvbn.version>
        <commons-lang3.version>3.20.0</commons-lang3.version>
        <guava.version>33.4.8-jre</guava.version>
        <jjwt.version>0.11.5</jjwt.version>
        <mapstruct.version>1.6.3</mapstruct.version>
        <lombok.version>1.18.38</lombok.version>
        <lombok-mapstruct-binding.version>0.2.0</lombok-mapstruct-binding.version>
        <exec-maven-plugin.version>3.5.0</exec-maven-plugin.version>
    </properties>
    <dependencyManagement>
